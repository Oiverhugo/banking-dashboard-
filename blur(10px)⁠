<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Banking Dashboard Card</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: #f4f6f8;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        /* Dashboard Container */
        .dashboard-card {
            background: #ffffff;
            width: 100%;
            max-width: 380px;
            border-radius: 24px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            overflow: hidden;
            padding: 16px;
        }

        /* Blue Balance Card */
        .balance-card {
            background: linear-gradient(135deg, #0f4c92 0%, #082f63 100%);
            color: #ffffff;
            border-radius: 20px;
            padding: 24px 20px;
            position: relative;
        }

        .balance-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 14px;
            font-weight: 500;
            opacity: 0.9;
            margin-bottom: 8px;
        }

        /* Eye icon placeholder */
        .hide-balance-btn {
            background: none;
            border: none;
            color: white;
            cursor: pointer;
            opacity: 0.8;
            font-size: 16px;
        }

        .balance-amount {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: -0.5px;
            margin-bottom: 20px;
        }

        /* Inner Account Management Panel */
        .account-status-panel {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 14px;
            padding: 12px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .status-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* Shield Icon Placeholder */
        .shield-icon {
            width: 32px;
            height: 32px;
            background: rgba(255, 255, 255, 0.15);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
        }

        .account-info {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .account-label {
            font-size: 12px;
            font-weight: 500;
            opacity: 0.9;
        }

        .status-badge {
            background: #ffebe9;
            color: #ea3a3a;
            font-size: 10px;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            width: fit-content;
        }

        .status-badge::before {
            content: "●";
            font-size: 8px;
        }

        /* Action Buttons Inside Card */
        .status-actions {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .btn-action {
            border: none;
            border-radius: 8px;
            padding: 6px 12px;
            font-size: 11px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
            transition: background 0.2s ease;
        }

        .btn-white {
            background: #ffffff;
            color: #082f63;
        }

        .btn-blue {
            background: #16427a;
            color: #ffffff;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* Bottom Welcome Section */
        .welcome-section {
            padding: 24px 8px 12px 8px;
        }

        .welcome-title {
            color: #1a1a1a;
            font-size: 20px;
            font-weight: 700;
            line-height: 1.3;
            margin-bottom: 8px;
        }

        .welcome-subtitle {
            color: #757575;
            font-size: 14px;
            line-height: 1.4;
        }
    </style>
</head>
<body>

<div class="dashboard-card">
    <div class="balance-card">
        <div class="balance-header">
            <span>Available Balance</span>
            <button class="hide-balance-btn" aria-label="Hide balance">👁</button>
        </div>
        <div class="balance-amount">$1,000,000 USD</div>
        
        <div class="account-status-panel">
            <div class="status-left">
                <div class="shield-icon">🛡️</div>
                <div class="account-info">
                    <span class="account-label">Your Account</span>
                    <span class="status-badge">Inactive</span>
                </div>
            </div>
            <div class="status-actions">
                <button class="btn-action btn-white">📈 Transactions</button>
                <button class="btn-action btn-blue">📥 Top up</button>
            </div>
        </div>
    </div>

    <div class="welcome-section">
        <h2 class="welcome-title">What would you like to do today?</h2>
        <p class="welcome-subtitle">Choose from our popular actions below</p>
    </div>
</div>

</body>
</html>
